generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

enum UserRole {
  USER        // Job seeker
  ADMIN       // Interviewer/HR
  SUPER_ADMIN // Platform admin
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  password      String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  skills        String[]  @default([])  // ✅ ADD THIS
  
  jobs          Job[]
  accounts      Account[]
  sessions      Session[]
  resumes       Resume[]
  interviewResponses InterviewResponse[] 
}

model Resume {
  id            String     @id @default(uuid())
  fileName      String
  originalName  String
  fileSize      Int
  mimeType      String
  filePath      String
  tags          String[]
  isDefault     Boolean    @default(false)
  uploadedAt    DateTime    @default(now())
  userId        String
  user          User        @relation(fields:[userId], references: [id], onDelete:Cascade)
}
model Job {
  id                String    @id @default(uuid())
  company           String
  role              String
  status            JobStatus @default(APPLIED)
  location          String?
  jobDescription    String?
  extractedSkills   String[]
  salary            String?
  jobUrl            String?
  description       String?
  notes             String?
  
  appliedDate       DateTime  @default(now())
  interviewDate     DateTime?
  lastReminderSent  DateTime?
  
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  interviewQuestions InterviewQuestion[]
}

//Add new model for interview questions
model InterviewQuestion {
  id                String    @id @default(uuid())
  question          String  
  category          String  //e.g., "Technical", "Behavioural", "Role-specific"
  difficulty        String  //e.g., "Easy", "Medium", "Hard"
  jobId             String  
  job               Job       @relation(fields: [jobId],references: [id], onDelete: Cascade)
  createdAt         DateTime  @default(now())
  responses         InterviewResponse[]
}

//Add model for interview responses (for tracking practice)
model InterviewResponse{
  id                String    @id @default(uuid())
  questionId        String    
  question          InterviewQuestion @relation(fields: [questionId], references: [id],onDelete: Cascade)
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  answer            String? //User's answer
  transcript        String? //Speech-to-text transcript(for later)
  confidenceScore   Float?  //AI confidence analysis (0-100)
  contentScore      Float?  //Answer quality score(0-100)
  feedback          String? //AI feedback
  createdAt         DateTime    @default(now())
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum JobStatus {
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
}